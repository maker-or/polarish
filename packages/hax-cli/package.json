{
	"name": "@polarish/cli",
	"version": "0.1.0",
	"description": "Polarish CLI — configure and run the local AI bridge",
	"type": "module",
	"homepage": "https://polarish.dev",
	"repository": {
		"type": "git",
		"url": "https://github.com/anomalyco/polarish.git"
	},
	"bugs": {
		"url": "https://github.com/anomalyco/polarish/issues"
	},
	"keywords": [
		"cli",
		"polarish",
		"ai",
		"bridge",
		"localhost",
		"openai",
		"codex"
	],
	"files": ["bin", "dist", "public"],
	"bin": {
		"polarish": "./bin/run.js"
	},
	"oclif": {
		"bin": "polarish",
		"dirname": "polarish",
		"commands": "./dist/commands",
		"topicSeparator": " ",
		"hooks": {
			"init": "./dist/hooks/init.js",
			"postrun": "./dist/hooks/postrun.js"
		}
	},
	"scripts": {
		"build": "rm -rf dist && tsc -p tsconfig.build.json",
		"lint": "biome check .",
		"typecheck": "tsc --noEmit -p tsconfig.json",
		"prepack": "bun run build"
	},
	"engines": {
		"node": ">=20"
	},
	"dependencies": {
		"@oclif/core": "^4.2.10",
		"dotenv": "^16.4.7",
		"inquirer": "^13.4.0",
		"keytar": "^7.9.0",
		"ora": "^9.3.0",
		"semver": "^7.7.2"
	},
	"devDependencies": {
		"@types/node": "^24.10.1",
		"@types/semver": "^7.7.0",
		"typescript": "~5.9.3"
	}
}
