{
	"compilerOptions": {
		"paths": {
			"#tool-callback-host": ["./client/tool-callback-host.node.ts"]
		},
		// Environment setup & latest features
		"lib": ["ESNext"],
		"target": "ESNext",
		"module": "Preserve",
		"moduleDetection": "force",
		"jsx": "react-jsx",
		"allowJs": true,

		// Bundler mode; explicit `.ts` paths match on-disk sources (Turbopack) and rewrite to `.js` on emit.
		"moduleResolution": "bundler",
		"allowImportingTsExtensions": true,
		"verbatimModuleSyntax": true,
		"noEmit": true,

		// Best practices
		"strict": true,
		"exactOptionalPropertyTypes": true, // optional
		"skipLibCheck": true,
		"noFallthroughCasesInSwitch": true,
		"noUncheckedIndexedAccess": true,
		"noImplicitOverride": true,

		// Some stricter flags (disabled by default)
		"noUnusedLocals": false,
		"noUnusedParameters": false,
		"noPropertyAccessFromIndexSignature": false
	},
	"include": [
		"./index.ts",
		"./types.ts",
		"./client/**/*.ts",
		"./history/**/*.ts",
		"./runtime/**/*.ts",
		"./providers/**/*.ts"
	],
	"exclude": ["./dist", "./node_modules", "**/*.e2e.test.ts"]
}
