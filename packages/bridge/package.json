{
	"name": "@polarish/bridge",
	"version": "0.1.0",
	"type": "module",
	"files": ["dist/**/*.js", "dist/**/*.d.ts", "README.md"],
	"main": "./dist/index.js",
	"types": "./dist/index.d.ts",
	"exports": {
		".": {
			"types": "./dist/index.d.ts",
			"import": "./dist/index.js",
			"default": "./dist/index.js"
		},
		"./package.json": "./package.json"
	},
	"scripts": {
		"build": "bun x tsc -p ./tsconfig.build.json",
		"lint": "bun x @biomejs/biome check src package.json tsconfig.json tsconfig.build.json",
		"typecheck": "bun x tsc -p ./tsconfig.json --noEmit"
	},
	"devDependencies": {
		"@types/bun": "latest"
	}
}
