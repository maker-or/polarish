{
  "name": "hax",
  "private": true,
  "packageManager": "bun@1.2.22",
  "workspaces": [
    "apps/*",
    "packages/*"
  ],
  "scripts": {
    "dev": "turbo dev",
    "build": "turbo build",
    "lint": "turbo lint",
    "typecheck": "turbo typecheck",
    "cli": "node ./packages/hax-cli/bin/run.js",
    "cli:build": "bun run --cwd packages/hax-cli build"
  },
  "dependencies": {
    "@types/node": "^25.5.0",
    "openai": "^6.32.0"
  },
  "devDependencies": {
    "@biomejs/biome": "^1.9.4",
    "turbo": "^2.8.20",
    "typescript": "~5.9.3"
  }
}
