{
  "name": "hax",
  "private": true,
  "packageManager": "bun@1.2.22",
  "workspaces": ["apps/*", "packages/*"],
  "scripts": {
    "dev": "turbo dev",
    "build": "turbo build",
    "lint": "turbo lint",
    "typecheck": "turbo typecheck",
    "desktop:dev": "turbo dev --filter=desktop",
    "web:dev": "turbo dev --filter=web",
    "desktop:dist": "bun --cwd apps/desktop run dist",
    "desktop:dist:dir": "bun --cwd apps/desktop run dist:dir"
  },
  "dependencies": {
    "@dodopayments/convex": "^0.2.8",
    "@types/node": "^25.5.0",
    "convex": "^1.34.0",
    "openai": "^6.32.0"
  },
  "devDependencies": {
    "@biomejs/biome": "^1.9.4",
    "@effect/language-service": "^0.80.0",
    "turbo": "^2.8.20",
    "typescript": "~5.9.3"
  }
}
